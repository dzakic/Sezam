@page "/Conference/{ConfName}/{TopicName?}"
@model Sezam.Web.Pages.Conference.ConfModel

@{
    var title = Model.Topic != null ? Model.ConfName + " : " + Model.Topic?.Name : Model.ConfName;
    if (Model.PageNumber > 1) title += $" - Page {Model.PageNumber}";
    ViewData["Title"] = title;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

@section Meta {
    @if (Model.PageNumber > 1)
    {
        <link rel="prev" href="@Url.Page("./Conf", new { ConfName = Model.ConfName, TopicName = Model.TopicName, p = Model.PageNumber - 1 })" />
    }
    @if (Model.PageNumber < Model.TotalPages)
    {
        <link rel="next" href="@Url.Page("./Conf", new { ConfName = Model.ConfName, TopicName = Model.TopicName, p = Model.PageNumber + 1 })" />
    }
    <link rel="canonical" href="@Url.Page("./Conf", new { ConfName = Model.ConfName, TopicName = Model.TopicName, p = Model.PageNumber > 1 ? (int?)Model.PageNumber : null })" />
}

<h1>@Model.ConfName</h1>

<p>@string.Format("{0:dd MMM yyyy} - {1:dd MMM yyyy}", Model.Conference.FromDate, Model.Conference.ToDate)</p>

<div id="Topics">
    <h2>Topics</h2>
    <ol>
        @foreach (var topic in Model.ConfTopics)
        {
            <li value="@topic.TopicNo"><a asp-page="./Conf" asp-route-ConfName="@Model.Conference.VolumeName" asp-route-TopicName="@topic.Name">@topic.Name</a> (@topic.NextSequence)</li>
        }
    </ol>
</div>

<div id="Messages">
    <h2>Messages - @Model.Topic?.Name</h2>
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation top">
            <ul class="pagination pagination-sm">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item"><a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@(Model.PageNumber - 1)">Previous</a></li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@i">@i</a>
                        </li>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item"><a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@(Model.PageNumber + 1)">Next</a></li>
                }
            </ul>
        </nav>
    }
    @if (Model.Messages != null)
    {
        @foreach (var msg in Model.Messages)
        {
            <message>
                <header>
                    <msgid>@msg.MsgId</msgid>
                    <author>@msg.AuthorUsername</author>,
                    <time title="@string.Format("{0:dd/MM/yyyy HH:mm}", msg.Time)">@string.Format("{0:dd MMM yy}", msg.Time)</time>
                    @if (msg.ParentMsgNo is not null)
                    {
                        <reply>-> #@msg.ParentMsgNo, @msg.ParentAuthorUsername</reply>
                    }
                </header>
                <content>@msg.Text</content>
                @if(msg.Filename.Length > 0)
                {
                    <file>@msg.Filename</file>
                }
            </message>
        }
    }
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation bottom">
            <ul class="pagination">
                @if (Model.PageNumber > 1)
                {
                    <li class="page-item"><a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@(Model.PageNumber - 1)">Previous</a></li>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@i">@i</a>
                        </li>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }
                @if (Model.PageNumber < Model.TotalPages)
                {
                    <li class="page-item"><a class="page-link" asp-route-ConfName="@Model.ConfName" asp-route-TopicName="@Model.TopicName" asp-route-p="@(Model.PageNumber + 1)">Next</a></li>
                }
            </ul>
        </nav>
    }
</div>

